{
  "adapter": "csv",
  "delimiter": "\t",
  "mapping": {
    "timestamp": { "column": "timestamp" },
    "modality": { "value": "olfaction_aggregate" },
    "source": { "column": "compound_id" },
    "signal_type": { "column": "descriptor" },
    "value": { "column": "value", "cast": "float" },
    "unit": { "value": "rating" },
    "context": {
      "include": ["sigma", "challenge_split"],
      "static": {
        "dataset": "DREAM Olfaction Prediction Challenge",
        "temporal_basis": "synthetic_sequence"
      }
    },
    "temporal": {
      "event_kind": { "value": "observation" },
      "stream_id": { "column": "compound_id" },
      "sequence_index": { "column": "sequence_index", "cast": "int" }
    }
  }
}
